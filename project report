                sentence_count,
                uppercase_ratio
            ])

        numeric_features = np.array(numeric_features, dtype="float32")

        numeric_scaled = self.scaler.transform(numeric_features)

        numeric_sparse = csr_matrix(numeric_scaled)

        return hstack([tfidf, numeric_sparse])

